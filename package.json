{
  "name": "@saberapp/n8n-nodes-saber",
  "version": "0.1.3",
  "description": "n8n community node for the Saber Platform API — AI-powered company and contact research signals, market signals, lists, and scoring.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "saber",
    "sales-intelligence",
    "company-research",
    "contact-research",
    "market-signals"
  ],
  "license": "MIT",
  "homepage": "https://github.com/saberapp/n8n-nodes-saber#readme",
  "author": {
    "name": "Saber",
    "email": "bohdan@saber.app",
    "url": "https://saber.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saberapp/n8n-nodes-saber.git"
  },
  "bugs": {
    "url": "https://github.com/saberapp/n8n-nodes-saber/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lint:fix": "eslint nodes credentials package.json --fix",
    "generate": "tsx scripts/generate-operations.ts",
    "scan": "npx --yes @n8n/scan-community-package @saberapp/n8n-nodes-saber",
    "prepublishOnly": "npm run build && eslint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SaberApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Saber/Saber.node.js",
      "dist/nodes/SaberTrigger/SaberTrigger.node.js"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "js-yaml": "^4.1.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
